rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════
// Reglas de producción — Sistema de Muestristas · Deportivos Quini
//
// Contexto: la app NO usa Firebase Auth (el login es por PIN de 6 dígitos
// validado en el cliente contra la colección `pines`). Por eso estas reglas
// no pueden distinguir usuarios; lo que sí hacen es:
//   1. Reemplazar el "modo prueba" que vence a los 30 días (sin estas
//      reglas, la app dejaría de funcionar al vencer).
//   2. Limitar el acceso EXCLUSIVAMENTE a las 4 colecciones de la app —
//      cualquier otra colección queda bloqueada.
//   3. Validar la forma de los datos (tipos, estados válidos, formato de
//      PIN, usuarios conocidos, firmas PNG bien formadas, tiempos
//      coherentes) para que un cliente con errores o un tercero no pueda
//      corromper los documentos.
//   4. Proteger campos sensibles: en `desarrollos` no se pueden reescribir
//      complejidad/asignación/variantes; una ficha aprobada solo puede
//      reabrirse (no editarse); los estados firmados exigen su firma.
//   5. Prohibir borrados: el historial de fichas es un registro de trabajo.
//
// Mejora futura (cuando se active el plan Blaze / Firebase Auth): usar
// Auth anónimo + custom claims para amarrar cada rol a su dispositivo.
//
// Despliegue:  firebase deploy --only firestore:rules
// ═══════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function esUsuario(uid) {
      return uid in ['lety', 'israel', 'jesus'];
    }
    function esMuestrista(uid) {
      return uid in ['israel', 'jesus'];
    }
    function estadoCapturaValido(e) {
      return e in ['activo', 'pausado', 'pendiente_lety', 'correccion', 'aprobado'];
    }
    function estadoDesarrolloValido(e) {
      return e in ['pendiente', 'en_proceso'];
    }
    // Firma: ausente, null, o data-URL PNG bien formado (la app solo
    // renderiza este formato; bloquea payloads de XSS almacenado)
    function firmaOk(data, campo) {
      return !(campo in data) || data[campo] == null
        || (data[campo] is string
            && data[campo].size() < 300000
            && data[campo].matches('data:image/png;base64,[A-Za-z0-9+/=]+'));
    }
    // Tiempos coherentes: números no negativos, TM nunca mayor que el bruto
    function tiemposOk(data) {
      return data.elapsed_seg is number && data.tm_seg is number
        && data.elapsed_seg >= 0 && data.tm_seg >= 0
        && data.tm_seg <= data.elapsed_seg
        && (!('tm_causas' in data) || data.tm_causas is map);
    }

    // ── desarrollos: tareas que Lety asigna ──
    match /desarrollos/{devId} {
      allow read: if true;
      allow create: if request.resource.data.modelo is string
                    && request.resource.data.modelo.size() > 0
                    && esMuestrista(request.resource.data.asignado_a)
                    && estadoDesarrolloValido(request.resource.data.estado)
                    && request.resource.data.tipo_complejidad in ['A', 'B', 'C']
                    && request.resource.data.variantes is list
                    && request.resource.data.variantes.size() > 0;
      // La app solo cambia `estado`; los campos sensibles son inmutables
      allow update: if estadoDesarrolloValido(request.resource.data.estado)
                    && request.resource.data.get('tipo_complejidad', '') == resource.data.get('tipo_complejidad', '')
                    && request.resource.data.get('asignado_a', '') == resource.data.get('asignado_a', '')
                    && request.resource.data.get('variantes', []) == resource.data.get('variantes', [])
                    && request.resource.data.get('creado_por', '') == resource.data.get('creado_por', '');
      allow delete: if false;
    }

    // ── capturas: fichas prácticas (una por variante) ──
    match /capturas/{capId} {
      allow read: if true;
      allow create: if esMuestrista(request.resource.data.id_muestrista)
                    && request.resource.data.id_desarrollo is string
                    && request.resource.data.codigo_variante is string
                    && request.resource.data.estado == 'activo'
                    && tiemposOk(request.resource.data)
                    && firmaOk(request.resource.data, 'firma_m')
                    && firmaOk(request.resource.data, 'firma_l');
      allow update: if estadoCapturaValido(request.resource.data.estado)
                    // El dueño, el desarrollo de origen y la variante no se reasignan
                    && request.resource.data.id_muestrista == resource.data.id_muestrista
                    && request.resource.data.id_desarrollo == resource.data.id_desarrollo
                    && request.resource.data.get('codigo_variante', '') == resource.data.get('codigo_variante', '')
                    && tiemposOk(request.resource.data)
                    && firmaOk(request.resource.data, 'firma_m')
                    && firmaOk(request.resource.data, 'firma_l')
                    // Una ficha aprobada solo puede reabrirse a pendiente_lety
                    && (resource.data.estado != 'aprobado'
                        || request.resource.data.estado == 'pendiente_lety')
                    // Una ficha firmada (pendiente) solo se aprueba o se rechaza:
                    // nadie puede seguir editando sus tiempos congelados
                    && (resource.data.estado != 'pendiente_lety'
                        || request.resource.data.estado in ['aprobado', 'correccion'])
                    // El estado 'aprobado' solo puede llegar desde 'pendiente_lety'
                    // (evita saltarse el flujo de firma de Lety)
                    && (request.resource.data.estado != 'aprobado'
                        || resource.data.estado == 'pendiente_lety')
                    // Los estados firmados exigen su firma correspondiente
                    && (request.resource.data.estado != 'pendiente_lety'
                        || (('firma_m' in request.resource.data) && request.resource.data.firma_m is string))
                    && (request.resource.data.estado != 'aprobado'
                        || (('firma_l' in request.resource.data) && request.resource.data.firma_l is string))
                    && (request.resource.data.estado != 'aprobado'
                        || (('firma_m' in request.resource.data) && request.resource.data.firma_m is string));
      allow delete: if false;
    }

    // ── pines: PIN de acceso por usuario (doc id = uid) ──
    match /pines/{uid} {
      allow read: if esUsuario(uid);
      allow write: if esUsuario(uid)
                   && request.resource.data.keys().hasOnly(['pin'])
                   && request.resource.data.pin is string
                   && request.resource.data.pin.matches('^[0-9]{6}$');
    }

    // ── _ping: test de conectividad (write de prueba al arrancar) ──
    match /_ping/{docId} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['ts'])
                   && request.resource.data.ts is number;
    }

    // ── Todo lo demás: bloqueado ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
